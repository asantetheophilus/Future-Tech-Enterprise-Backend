# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string. Create a database named pulse_commerce first.
DATABASE_URL="mysql://root:your_password@localhost:3306/pulse_commerce"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN="http://localhost:3000"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MINIMUM 32 characters. Use different values for access and refresh!
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For development use Mailtrap: https://mailtrap.io
# For production use SendGrid, Mailgun, or Postmark
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_pass

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Store WhatsApp number for order notifications (international format, no +)
WHATSAPP_NUMBER=233540000000

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
